{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "DbPath": "/data/savelocker.db",
    "ArchiveRoot": "/data/archives",
    "AgentInstallerRoot": "/data/agent-installer",
    "MaxUploadMb": 200
  },
  "Sync": {
    "DefaultExcludeGlobs": [ "*.tmp", "*.log", "*.bak", "Thumbs.db", "desktop.ini" ]
  },
  "Backup": {
    "RetentionCount": 7,
    "HourOfDay": 3,
    "Enabled": true
  },
  "AgentUpdate": {
    "LatestVersion": "",
    "DownloadUrl": "",
    "GitHubRepo": "SkorcherX/SaveLocker"
  }
}
