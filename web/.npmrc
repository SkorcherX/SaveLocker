# The dashboard runs deliberately ahead of some tools' peer ranges (TypeScript 6,
# Vite 8). openapi-typescript@7 still declares a typescript@^5 peer even though it
# generates fine under TS 6 (types are verified by `npm run build`/tsc). Accept the
# newer peer instead of failing installs. Honored by `npm ci` in the Docker build.
legacy-peer-deps=true
