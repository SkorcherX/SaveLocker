# Build output
**/bin/
**/obj/

# Local runtime state (SQLite db + archives)
**/localstate/
# Only ignore root-level data/ (runtime DB mount), not src/Server/Data/ source folder
/data/

# Test scratch
/.verify/
/crossos-work/

# NEVER commit a real server database. A copy of production is sometimes pulled in to test a
# migration against real data (see tasks/dotnet-10-upgrade.md Phase 4) — it holds machine API key
# hashes, machine names, save paths and the audit log, and this repo is public.
*.db
*.db-wal
*.db-shm

# IDE / user files
*.user
.vs/

# Obsidian per-session UI state (keep app.json / appearance.json / core-plugins.json).
# The vault folder was renamed LocalGameSync -> SaveLocker; these rules still said LocalGameSync,
# so they matched nothing and workspace.json showed up dirty every single session.
SaveLocker/.obsidian/workspace.json
SaveLocker/.obsidian/workspace-mobile.json
SaveLocker/.obsidian/graph.json

# Secrets — never commit real keys here; appsettings.Development.json is tracked with placeholders

# wwwroot is generated by the Docker build (web stage → COPY dist/ into wwwroot/)
# Never commit build output here; the Dockerfile handles it.
src/Server/wwwroot/

# Local Claude Code session settings
.claude/settings.local.json

# Node
agent-ui/node_modules/
agent-ui/dist/
web/node_modules/

# Built installer binaries
installer/dist/
.verify-linux/
.verify-health/
artifacts/
.verify-harden/
