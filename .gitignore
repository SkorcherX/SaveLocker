# Build output
**/bin/
**/obj/

# Local runtime state (SQLite db + archives)
**/localstate/
# Only ignore root-level data/ (runtime DB mount), not src/Server/Data/ source folder
/data/

# Test scratch
/.verify/

# IDE / user files
*.user
.vs/

# Obsidian per-session UI state (keep app.json / appearance.json / core-plugins.json)
LocalGameSync/.obsidian/workspace.json
LocalGameSync/.obsidian/workspace-mobile.json
LocalGameSync/.obsidian/graph.json

# Secrets — never commit real keys here; appsettings.Development.json is tracked with placeholders

# wwwroot is generated by the Docker build (web stage → COPY dist/ into wwwroot/)
# Never commit build output here; the Dockerfile handles it.
src/Server/wwwroot/

# Local Claude Code session settings
.claude/settings.local.json

# Node
agent-ui/node_modules/
agent-ui/dist/
web/node_modules/

# Built installer binaries
installer/dist/
